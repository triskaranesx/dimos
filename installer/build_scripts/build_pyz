#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
OUT="$ROOT/installer.pyz"
BUILD="$ROOT/.build_pyz"

rm -rf "$BUILD"
mkdir -p "$BUILD/app"

# Rebuild embedded dependency database and project toml snapshot
python3 "$ROOT/build_scripts/build_pip_dependency_database.py"

# Copy your code in
rsync -a "$ROOT/pyz_app/" "$BUILD/app/pyz_app/"

# Install dependencies into the app directory
python3 -m pip install -r "$ROOT/requirements.txt" -t "$BUILD/app" >/dev/null

# Build the zipapp. main points to pyz_app.__main__:main
python3 -m zipapp "$BUILD/app" \
  -o "$OUT" \
  -m "pyz_app.__main__:main"

echo "Built: $OUT"
echo "Run:   python3 $OUT"
